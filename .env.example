# =============================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# BASE DE DATOS — MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<nombre_db>?retryWrites=true&w=majority&appName=<appName>
# Obtener desde: https://cloud.mongodb.com → tu cluster → Connect → Drivers → Node.js
# =============================================
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/basketball_liga?retryWrites=true&w=majority&appName=TPApis

# =============================================
# JWT — Autenticación
# Generar un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================
JWT_SECRET=reemplazar_con_string_aleatorio_largo
JWT_EXPIRES_IN=8h

# =============================================
# CORS — Solo necesario en producción
# Poner la URL del frontend desplegado (ej: Vercel)
# =============================================
# CORS_ORIGIN=https://tu-frontend.vercel.app
